<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <rule name="Token Routing" stopProcessing="true">
                    <match url="^$" />
                    <conditions>
                        <add input="{QUERY_STRING}" pattern="(^|&amp;)(tkn/pg)=" />
                    </conditions>
                    <action type="Rewrite" url="request.php" />
                </rule>
                <rule name="Global Educore Router" stopProcessing="true">
                    <match url="^(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="request.php" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>
        <defaultDocument>
            <files>
                <remove value="index.php" />
                <add value="index.php" />
            </files>
        </defaultDocument>
        <urlCompression doDynamicCompression="false" />
        <directoryBrowse enabled="false" />
        <httpErrors errorMode="Custom" />
    </system.webServer>
    <system.web>
        <authentication mode="Forms" />
    </system.web>
</configuration>
